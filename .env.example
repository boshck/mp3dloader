# =============================================================================
# AMusic Bot - Конфигурация
# =============================================================================
# Скопируйте этот файл в .env и заполните значения
# Никогда не коммитьте .env в Git!
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
# Токен основного бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# -----------------------------------------------------------------------------
# Администратор
# -----------------------------------------------------------------------------
# Токен бота для отправки уведомлений админу (может быть тот же или отдельный)
# Необходим для получения уведомлений о критических событиях (истечение токенов, ошибки)
ADMIN_BOT_TOKEN=your_admin_bot_token_here

# ID чата для уведомлений (ваш Telegram ID или ID группы)
# Получить ID можно у @userinfobot
ADMIN_CHAT_ID=your_telegram_id_here

# Секретная команда для сброса лимитов (используйте сложную строку)
# ВАЖНО: используйте вместе с whitelisting по ID пользователей!
ADMIN_BACKDOOR_COMMAND=your_secret_command_here

# -----------------------------------------------------------------------------
# VK API
# -----------------------------------------------------------------------------
# Список VK токенов (через запятую, без пробелов)
# При истечении токена (error_code 5) бот автоматически:
#   - Исключит токен из ротации
#   - Отправит уведомление админу с первыми 15 символами токена
#   - Продолжит работать с оставшимися токенами
# Рекомендуется иметь минимум 3-5 токенов для надёжной работы
#
# Как получить токен:
#   1. Перейдите на vk.com/dev
#   2. Создайте Standalone-приложение
#   3. Получите токен с правами: audio, offline
#
VK_TOKENS=vk1.a.TOKEN1,vk1.a.TOKEN2,vk1.a.TOKEN3

# Альтернативный вариант (устаревший, используйте VK_TOKENS)
# VK_TOKEN=vk1.a.YOUR_TOKEN_HERE

# -----------------------------------------------------------------------------
# Redis (опционально)
# -----------------------------------------------------------------------------
# URL для подключения к Redis (используется для rate limiting и кэширования)
# Если Redis недоступен, бот переключится в in-memory режим
# Windows: установите Memurai (аналог Redis для Windows)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Ограничения (Rate Limiting)
# -----------------------------------------------------------------------------
# Лимит операций на пользователя за окно USER_WINDOW_MINUTES
OPERATIONS_PER_USER=15

# Окно времени для лимита пользователя (минуты)
USER_WINDOW_MINUTES=60

# Глобальный лимит операций за окно GLOBAL_WINDOW_MINUTES
GLOBAL_OPERATIONS_LIMIT=300

# Окно времени для глобального лимита (минуты)
GLOBAL_WINDOW_MINUTES=60

# TTL кэша результатов поиска (секунды)
SEARCH_CACHE_TTL=1800

# -----------------------------------------------------------------------------
# Ограничения контента
# -----------------------------------------------------------------------------
# Максимальный размер файла для скачивания (МБ)
MAX_FILE_SIZE_MB=100

# Максимальная длительность трека (минуты)
MAX_TRACK_DURATION_MINUTES=60

# Максимальное количество закэшированных треков
MAX_CACHED_TRACKS=200

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------
# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Отправка архивов логов администратору (true/false)
SEND_LOG_ARCHIVES=true

# Интервал отправки архивов логов (часы)
LOG_ARCHIVE_INTERVAL_HOURS=6

# Максимальное количество файлов в архиве
LOG_ARCHIVE_MAX_FILES=6

# Максимальный размер архива логов (МБ)
LOG_ARCHIVE_MAX_TOTAL_MB=50

# -----------------------------------------------------------------------------
# Дополнительные настройки
# -----------------------------------------------------------------------------
# Все остальные настройки находятся в bot/config/settings.py
# и могут быть переопределены через переменные окружения

# =============================================================================
# Примеры использования
# =============================================================================
#
# Разработка (локально):
#   - Redis необязателен (будет in-memory режим)
#   - Можно использовать один VK токен
#   - LOG_LEVEL=DEBUG для подробных логов
#
# Продакшн (сервер):
#   - Установите Redis для персистентного кэширования
#   - Используйте 3-5 VK токенов
#   - LOG_LEVEL=INFO для оптимальной производительности
#   - Настройте systemd/supervisor для автозапуска
#   - Обязательно настройте ADMIN_BOT_TOKEN и ADMIN_CHAT_ID
#
# =============================================================================
